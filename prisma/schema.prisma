generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id                String   @id @default(uuid())
  telegramId        String   @unique @map("telegram_id")
  name              String
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  members           Member[]
  schedulingRounds  SchedulingRound[]
  
  @@index([telegramId])
  @@map("groups")
}

model Member {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  groupId     String   @map("group_id")
  optedIn     Boolean  @default(false) @map("opted_in")
  optedInAt   DateTime? @map("opted_in_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@map("members")
}

model SchedulingRound {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  topic       String
  timeframe   String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  availabilityResponses AvailabilityResponse[]
  
  @@index([groupId])
  @@index([groupId, status])
  @@map("scheduling_rounds")
}

model AvailabilityResponse {
  id                String   @id @default(uuid())
  roundId           String   @map("round_id")
  userId            String   @map("user_id")
  rawResponse       String   @map("raw_response")
  parsedAvailability Json?   @map("parsed_availability")
  status            String   @default("pending") // pending, confirmed, corrected
  confirmedAt       DateTime? @map("confirmed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  round             SchedulingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  
  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId])
  @@index([status])
  @@map("availability_responses")
}
