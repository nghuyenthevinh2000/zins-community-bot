generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id                String   @id @default(uuid())
  telegramId        String   @unique @map("telegram_id")
  name              String
  
  // Story 5.2: Configurable nudge settings
  nudgeIntervalHours Int     @default(24) @map("nudge_interval_hours")
  maxNudgeCount     Int      @default(3) @map("max_nudge_count")
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  members           Member[]
  schedulingRounds  SchedulingRound[]
  nudgeHistory      NudgeHistory[]
  
  @@index([telegramId])
  @@map("groups")
}

model Member {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  groupId     String   @map("group_id")
  optedIn     Boolean  @default(false) @map("opted_in")
  optedInAt   DateTime? @map("opted_in_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@map("members")
}

model SchedulingRound {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  topic       String
  timeframe   String
  status      String   @default("active")
  
  // Story 6.2: Meeting confirmation fields
  confirmedAt       DateTime? @map("confirmed_at")
  confirmedTimeSlot Json?    @map("confirmed_time_slot") // { startTime, endTime, attendeeCount, attendeeUserIds }
  consensusThreshold Int    @default(75) @map("consensus_threshold") // Default 75%
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  availabilityResponses AvailabilityResponse[]
  pendingNLURequests PendingNLURequest[]
  nudgeTrackings    NudgeTracking[]
  
  @@index([groupId])
  @@index([groupId, status])
  @@map("scheduling_rounds")
}

model AvailabilityResponse {
  id                String   @id @default(uuid())
  roundId           String   @map("round_id")

  userId            String   @map("user_id")
  rawResponse       String   @map("raw_response")
  parsedAvailability Json?   @map("parsed_availability")
  status            String   @default("pending") // pending, confirmed, corrected
  confirmedAt       DateTime? @map("confirmed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  round             SchedulingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  

  @@index([roundId])
  @@index([userId])
  @@index([status])
  @@index([roundId, userId])
  @@map("availability_responses")
}

model PendingNLURequest {
  id                String   @id @default(uuid())
  roundId           String   @map("round_id")
  userId            String   @map("user_id")
  rawResponse       String   @map("raw_response")
  retryCount        Int      @default(0) @map("retry_count")
  nextRetryAt       DateTime @map("next_retry_at")
  lastError         String?  @map("last_error")
  status            String   @default("pending") // pending, processing, completed, failed
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  round             SchedulingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([nextRetryAt])
  @@index([retryCount])
  @@map("pending_nlu_requests")
}

model NudgeTracking {
  id                String   @id @default(uuid())
  roundId           String   @map("round_id")
  userId            String   @map("user_id")
  nudgeCount        Int      @default(0) @map("nudge_count")
  lastNudgeAt       DateTime? @map("last_nudge_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  round             SchedulingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  
  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId])
  @@index([nudgeCount])
  @@map("nudge_tracking")
}

// Story 5.2: Nudge History model
model NudgeHistory {
  id                String   @id @default(uuid())
  groupId           String   @map("group_id")
  roundId           String   @map("round_id")
  userId            String   @map("user_id")
  nudgeNumber       Int      @map("nudge_number") // 1st, 2nd, 3rd nudge, etc.
  sentAt            DateTime @default(now()) @map("sent_at")
  
  group             Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@index([groupId])
  @@index([roundId])
  @@index([userId])
  @@index([groupId, userId, roundId])
  @@map("nudge_history")
}
